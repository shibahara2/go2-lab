# ============================================================
# .env.bridge.example — Bridge 用の全変数
# cp .env.bridge.example .env.bridge してから環境に合わせて編集してください。
# make sync-configs TARGET=bridge で configs/ 内のテンプレートに展開されます。
# ============================================================

# --- Zenoh ---
ZENOH_ROUTER_IP=135.149.56.251
ZENOH_ROUTER_PORT=7447

# --- Network ---
# Bridge を実行する Linux ホスト上で `ip link` などで確認した実在の IF 名に変更してください。
# `eno1` / `eth0` / `enp*` など、環境によって名称が異なります。
NETWORK_INTERFACE=CHANGE_ME

# --- LiDAR ---
LIDAR_HOST_IP=192.168.123.18
LIDAR_DEVICE_IP=192.168.123.20

# --- ROS ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
ROS_LOCALHOST_ONLY=1

# --- Docker ---
DOCKER_SHM_SIZE=4gb
