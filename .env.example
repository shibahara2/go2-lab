# ============================================================
# .env.example — shared environment variables for this host
# Copy to .env and edit values for the machine where this clone runs.
# This repo uses workstation host execution and an optional Jetson container.
# ============================================================

# --- Mode switch ---
# 0: workstation host-only development on this machine
# 1: distributed mode (jetson client + workstation client + external router)
DISTRIBUTED_MODE=0

# --- Zenoh (distributed mode only) ---
ZENOH_ROUTER_IP=192.168.11.4
ZENOH_ROUTER_PORT=7447
# Optional: increase wait time before zenoh drops oversized messages on congestion.
# Example:
# ZENOH_CONFIG_OVERRIDE=transport/link/tx/queue/congestion_control/drop/wait_before_drop=1000000
ZENOH_CONFIG_OVERRIDE=

# --- Network ---
# Set this to a real interface name on the current host, such as:
# eth0 / eno1 / enp* / wlp*
NETWORK_INTERFACE=CHANGE_ME

# --- LiDAR ---
LIDAR_HOST_IP=192.168.123.18
LIDAR_DEVICE_IP=192.168.123.20

# --- ROS ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# --- NVIDIA / Docker ---
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all
DOCKER_SHM_SIZE=4gb

# --- Host-only optional ---
LIDAR_DATASET_PATH=/data/LIDAR_dataset
