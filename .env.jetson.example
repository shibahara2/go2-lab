# ============================================================
# .env.jetson.example — Jetson 用の全変数
# cp .env.jetson.example .env.jetson してから環境に合わせて編集してください。
# make sync-configs TARGET=jetson で configs/ 内のテンプレートに展開されます。
# ============================================================

# --- Zenoh ---
ZENOH_ROUTER_IP=135.149.56.251
ZENOH_ROUTER_PORT=7447

# --- Network ---
NETWORK_INTERFACE=CHANGE_ME

# --- LiDAR ---
LIDAR_HOST_IP=192.168.123.18
LIDAR_DEVICE_IP=192.168.123.20

# --- ROS ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# --- NVIDIA ---
NVIDIA_DRIVER_CAPABILITIES=all
NVIDIA_VISIBLE_DEVICES=all

# --- Docker ---
DOCKER_SHM_SIZE=4gb
