# ============================================================
# .env.example — テンプレート変数の定義
# `cp .env.example .env` してから環境に合わせて編集してください。
# `make sync-configs` で configs/ 内のテンプレートに展開されます。
# ============================================================

# --- Zenoh ---
ZENOH_ROUTER_IP=192.168.11.4
ZENOH_ROUTER_PORT=7447

# --- Network ---
# NETWORK_INTERFACE はターゲット別ファイル (.env.<target>) で管理します。
# 例: cp .env.jetson.example .env.jetson

# --- LiDAR ---
LIDAR_HOST_IP=192.168.123.18
LIDAR_DEVICE_IP=192.168.123.20

# --- ROS ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# --- Docker ---
DOCKER_SHM_SIZE=4gb
LIDAR_DATASET_PATH=/data/LIDAR_dataset
