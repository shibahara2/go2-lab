# ============================================================
# .env.visualization-host.example — Visualization Host 用の全変数
# cp .env.visualization-host.example .env.visualization-host してから環境に合わせて編集してください。
# make sync-configs TARGET=visualization-host で configs/ 内のテンプレートに展開されます。
# ============================================================

# --- Zenoh ---
ZENOH_ROUTER_IP=192.168.11.4
ZENOH_ROUTER_PORT=7447

# --- Network ---
NETWORK_INTERFACE=wlp0s20f3

# --- LiDAR ---
LIDAR_HOST_IP=192.168.123.18
LIDAR_DEVICE_IP=192.168.123.20

# --- ROS ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# --- Docker ---
DOCKER_SHM_SIZE=4gb
LIDAR_DATASET_PATH=/data/LIDAR_dataset
